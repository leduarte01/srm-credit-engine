# Application
APP_ENV=local
APP_NAME=srm-credit-engine
APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_JSON=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://srm:srm@localhost:5432/srm_credit
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=srm-credit-engine
PROMETHEUS_ENABLED=true

# Pricing
BASE_RATE_MONTHLY=0.01
