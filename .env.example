# Override these to customise the docker-compose stack.
# Copy this file to .env at the repo root and adjust as needed.

# Postgres
POSTGRES_USER=srm
POSTGRES_PASSWORD=srm
POSTGRES_DB=srm_credit
POSTGRES_PORT=5432

# Backend
APP_ENV=production
LOG_LEVEL=INFO
API_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:8080
BACKEND_PORT=8000

# Frontend (served by nginx)
FRONTEND_PORT=8080
